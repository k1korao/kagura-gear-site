# Public site URL used for future analytics, canonical helpers, or Storefront API integrations.
NEXT_PUBLIC_SITE_URL=https://kaguragear.com

# Future Shopify Storefront API placeholders.
# Do not add Admin API secrets or payment credentials to frontend code.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-public-storefront-token

# Optional production contact form provider.
# The site still shows a direct support@kaguragear.com email fallback without these.
RESEND_API_KEY=your-resend-api-key
CONTACT_FROM_EMAIL=Kagura Gear <support@kaguragear.com>
CONTACT_TO_EMAIL=support@kaguragear.com

# Optional newsletter sender. If omitted, newsletter uses CONTACT_FROM_EMAIL.
# Customers receive an automatic welcome/recommended-products email after signup.
NEWSLETTER_FROM_EMAIL=Kagura Gear <support@kaguragear.com>
NEWSLETTER_NOTIFY_EMAIL=support@kaguragear.com
